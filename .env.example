# Required Telegram access.
TELEGRAM_TOKEN=your_telegram_bot_token
ALLOWED_USER_IDS=your_telegram_user_id

# Provider endpoints and keys live in ../.shared-ai.env, for example:
#   LLM_PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#   LLM_PROVIDER_OPENROUTER_API_KEY=your_openrouter_api_key
#   LLM_PROVIDER_OMLX_BASE_URL=http://127.0.0.1:8001/v1
#   LLM_PROVIDER_OMLX_API_KEY=your_omlx_api_key

# Default/API route. Tasks use this provider unless overridden below.
LLM_PROVIDER_NAME=OpenRouter

# Optional local oMLX helper routes while the default shared provider is OpenRouter.
# Remove these if every task should use the default provider.
LLM_REWRITE_PROVIDER_NAME=oMLX
LLM_PREFETCH_SUMMARY_PROVIDER_NAME=oMLX

# Optional additional named provider registry for task-specific cloud/API routing.
# LLM_PROVIDER_FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_PROVIDER_FIREWORKS_API_KEY=your_fireworks_api_key
# LLM_ROUTER_PROVIDER_NAME=fireworks

# Task model routing.
LLM_DEFAULT_MODEL=model-name
LLM_CHAT_MODEL=model-name
LLM_CONTEXT_MODEL=model-name
LLM_CONTEXT_SUMMARY_MODEL=model-name
LLM_CONTEXT_ANALYSIS_MODEL=model-name
LLM_ROUTER_MODEL=model-name
LLM_SUMMARY_MODEL=model-name
LLM_REWRITE_MODEL=model-name
LLM_PREFETCH_MODEL=model-name
LLM_PREFETCH_SUMMARY_MODEL=model-name

# Reasoning policy.
LLM_CHAT_REASONING_EFFORT=effort
LLM_CONTEXT_ANALYSIS_REASONING_EFFORT=effort
LLM_REASONING_EFFORT=
ENABLE_THINKING_FOR_CONTEXT=false

# OpenRouter routing policy. Remove or adjust for non-OpenRouter providers.
LLM_PROVIDER_DATA_COLLECTION=deny
LLM_REQUIRE_PARAMETERS=true
LLM_ZERO_DATA_RETENTION=false
# LLM_ALLOW_FALLBACKS=false

# Optional search.
TAVILY_API_KEY=your_tavily_api_key
ENABLE_AUTO_SEARCH=true

# Telegram delivery: final, draft, or edit.
TELEGRAM_RESPONSE_DELIVERY=draft

# Optional Vault and Inbox integration.
VAULT_CAPTURE_PATH=~/Atelier/Vault/Capture
INBOX_API_BASE_URL=http://localhost:8000
# INBOX_API_ACCESS_TOKEN=your_inbox_access_token
ENABLE_INBOX_CONTEXT_PREFETCH=true
ENABLE_INBOX_CONTEXT_PREFETCH_SUMMARY=false

# Optional extraction and cleanup fallbacks.
ENABLE_RESPONSE_VALIDATION=true
ENABLE_PLAYWRIGHT_FALLBACK=true
ENABLE_YOUTUBE_AUDIO_TRANSCRIPTION=false
