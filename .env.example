TELEGRAM_TOKEN=your_telegram_bot_token
TAVILY_API_KEY=your_tavily_api_key
ENABLE_AUTO_SEARCH=true
AUTO_SEARCH_CLASSIFIER_TIMEOUT_SECONDS=12
TELEGRAM_RESPONSE_DELIVERY=final
ENABLE_THINKING_FOR_CONTEXT=true
# LLM_DEFAULT_BASE_URL and LLM_DEFAULT_API_KEY may come from ../.shared-ai.env
# LLM_DEFAULT_BASE_URL=https://openrouter.ai/api/v1
# LLM_DEFAULT_API_KEY=
LLM_PROVIDER_NAME=OpenAI-compatible
LLM_DEFAULT_MODEL=deepseek/deepseek-v4-pro
LLM_CHAT_MODEL=deepseek/deepseek-v4-pro
LLM_CONTEXT_MODEL=deepseek/deepseek-v4-pro
LLM_ROUTER_MODEL=deepseek/deepseek-v4-pro
LLM_SUMMARY_MODEL=deepseek/deepseek-v4-pro
LLM_REWRITE_MODEL=deepseek/deepseek-v4-pro
LLM_PREFETCH_MODEL=deepseek/deepseek-v4-pro
LLM_CHAT_REASONING_EFFORT=xhigh
LLM_CONTEXT_REASONING_EFFORT=xhigh
LLM_REASONING_EFFORT=
LLM_PROVIDER_DATA_COLLECTION=deny
LLM_REQUIRE_PARAMETERS=true
LLM_ZERO_DATA_RETENTION=false
# LLM_ALLOW_FALLBACKS=
ALLOWED_USER_IDS=your_telegram_user_id
VAULT_CAPTURE_PATH=~/path/to/your/Vault/Capture
INBOX_API_BASE_URL=http://localhost:8000
# INBOX_API_ACCESS_TOKEN=
INBOX_API_TIMEOUT_SECONDS=10
INBOX_CONTEXT_SUMMARY_TIMEOUT_SECONDS=45
INBOX_CONTEXT_SUMMARY_MAX_INPUT_CHARS=12000
INBOX_CONTEXT_PREVIEW_CHARS=700
ENABLE_INBOX_CONTEXT_PREFETCH=true
INBOX_CONTEXT_PREFETCH_TARGET=5
INBOX_CONTEXT_PREFETCH_INTERVAL_SECONDS=60
INBOX_CONTEXT_PREFETCH_CACHE_TTL_SECONDS=21600
INBOX_CONTEXT_PREFETCH_PERSISTENT_CACHE_PATH=.cache/inbox-context-prefetch.sqlite3
ENABLE_INBOX_CONTEXT_PREFETCH_SUMMARY=false
INBOX_CONTEXT_PREFETCH_SUMMARY_TIMEOUT_SECONDS=180
ENABLE_RESPONSE_VALIDATION=true
RESPONSE_REWRITE_TIMEOUT_SECONDS=45
ENABLE_PLAYWRIGHT_FALLBACK=true
PLAYWRIGHT_RENDER_TIMEOUT_MS=12000
PLAYWRIGHT_IDLE_TIMEOUT_SECONDS=600
PLAYWRIGHT_MAX_QUEUE_SIZE=4
PLAYWRIGHT_QUEUE_WAIT_TIMEOUT_MS=1000
ENABLE_YOUTUBE_AUDIO_TRANSCRIPTION=false
YOUTUBE_AUDIO_TRANSCRIPTION_MAX_SECONDS=28800
YOUTUBE_AUDIO_TRANSCRIPTION_MAX_CONCURRENT=1
YOUTUBE_AUDIO_CHUNK_SECONDS=1800
YOUTUBE_AUDIO_DOWNLOAD_TIMEOUT_SECONDS=900
YOUTUBE_AUDIO_TRANSCRIPTION_TIMEOUT_SECONDS=0
YOUTUBE_AUDIO_TRANSCRIPTION_IDLE_TIMEOUT_SECONDS=900
YOUTUBE_AUDIO_CACHE_DIR=.cache/youtube-audio
YOUTUBE_TRANSCRIPT_CACHE_DIR=.cache/youtube-transcripts
YOUTUBE_AUDIO_KEEP_FILES=false
