TELEGRAM_TOKEN=your_telegram_bot_token
TAVILY_API_KEY=your_tavily_api_key
ENABLE_AUTO_SEARCH=true
AUTO_SEARCH_CLASSIFIER_TIMEOUT_SECONDS=12
TELEGRAM_RESPONSE_DELIVERY=final
ENABLE_THINKING_FOR_CONTEXT=false
LLM_API_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=
LLM_PROVIDER_NAME=OMLX
ALLOWED_USER_IDS=your_telegram_user_id
MODEL_NAME=your_llm_model_name
VAULT_CAPTURE_PATH=~/path/to/your/Vault/Capture
ENABLE_RESPONSE_VALIDATION=true
RESPONSE_REWRITE_TIMEOUT_SECONDS=45
ENABLE_PLAYWRIGHT_FALLBACK=true
PLAYWRIGHT_RENDER_TIMEOUT_MS=12000
PLAYWRIGHT_IDLE_TIMEOUT_SECONDS=600
PLAYWRIGHT_MAX_QUEUE_SIZE=4
PLAYWRIGHT_QUEUE_WAIT_TIMEOUT_MS=1000
